# ── /infra — LOCAL-ONLY ops/speed dashboard (never ship to main) ──────
# Runs in local dev; untracked so it stays off prod + main. The boot
# warmup (web/instrumentation.ts) is a real app perf win and STAYS tracked.
web/app/infra/
web/app/api/infra/
web/lib/infra-config.ts
web/lib/infra-probes.ts

# ── Beta product PAGES — LOCAL-ONLY until launch ─────────────────────
# Only the marketing surface is public for now: / , /waitlist , /litepaper.
# The web wallet, business workspace, admin tools, and the payment/profile
# link pages run in local dev but are untracked so they don't deploy. The
# API + auth routes they share (web/app/api/*, web/app/auth/*) STAY tracked —
# the iOS app + the waitlist depend on that live backend.
web/app/app/
web/app/business/
web/app/admin/
web/app/c/
web/app/i/
web/app/pay/
web/app/u/
.vercel
marketing/exports/
