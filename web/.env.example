# Talise web — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Google OAuth (zkLogin sign-in) ───────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:3000/auth/callback (+ https://talise.io/auth/callback in prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Sui network ──────────────────────────────────────────────────────
# "mainnet" requires SHINAMI_API_KEY (below) for zkLogin proofs.
# "testnet" uses Mysten's open testnet prover — fine for dev.
NEXT_PUBLIC_SUI_NETWORK=mainnet

# ── Shinami zkLogin (mainnet prover + salt service) ──────────────────
# Get a key at https://app.shinami.com. Replaces Mysten's audience-gated
# mainnet prover. Docs: https://docs.shinami.com/api-docs/sui/wallet-services/zklogin-wallet-api
SHINAMI_API_KEY=

# ── Gas sponsorship (Onara) ──────────────────────────────────────────
# Run locally: cd onara/api && bun run dev → http://localhost:8787
# Or deploy to Cloudflare Workers and point this at the prod URL.
ONARA_URL=http://localhost:8787

# When true (default), every signAndSubmit goes through Onara so the user
# never needs SUI for gas. Set false to fall back to sender-pays-gas.
NEXT_PUBLIC_SPONSOR_ENABLED=true

# ── Database ─────────────────────────────────────────────────────────
# Local dev: file:./.data/talise.db
# Production: libsql://<your-db>.turso.io with an auth token
DATABASE_URL=file:./.data/talise.db
DATABASE_AUTH_TOKEN=

# ── Session signing ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ── Resend (transactional email, optional) ───────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Talise <onboarding@resend.dev>
EMAIL_REPLY_TO=hello@talise.io

# ── Admin token ──────────────────────────────────────────────────────
ADMIN_TOKEN=

# ── Stripe Crypto Onramp ─────────────────────────────────────────────
# Server-only secret. Get a key at https://dashboard.stripe.com/apikeys
# (use the test-mode `sk_test_…` key for development; `sk_live_…` for prod).
#
# Crypto Onramp also requires enabling crypto in the Stripe dashboard:
#   Dashboard → Crypto → Get started → enable for your account.
#
# Note: Stripe Crypto Onramp delivers USDC on Sui mainnet (not USDsui directly).
# The AutoConvertBanner on /home sweeps inbound USDC → USDsui in one tap, so
# the user's net effect is "buy USDsui with a card".
STRIPE_SECRET_KEY=

# Public publishable key — only needed if/when we wire the embedded Onramp
# SDK. Today's flow uses `redirect_url` from the server-created session, so
# this is reserved for future use. Get it from the same dashboard page.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
