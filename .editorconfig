root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{swift,move}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml,json,jsonc,toml}]
indent_size = 2
