{
  "name": "@talise/cli",
  "version": "0.1.0",
  "description": "Talise wallet in your terminal — payments, natural language, agent-to-agent money on Sui.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://talise.io",
  "keywords": [
    "talise",
    "sui",
    "wallet",
    "cli",
    "payments",
    "stablecoin",
    "zklogin",
    "agent"
  ],
  "bin": {
    "talise": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "PLAN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --experimental-strip-types src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "prepare": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
