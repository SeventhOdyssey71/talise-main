{
  "name": "@talise/cli",
  "version": "0.1.0",
  "description": "Talise wallet in your terminal — payments, natural language, agent-to-agent money on Sui.",
  "type": "module",
  "license": "MIT",
  "author": "Talise",
  "homepage": "https://talise.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeventhOdyssey71/talise-main.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/SeventhOdyssey71/talise-main/issues"
  },
  "keywords": [
    "talise",
    "sui",
    "wallet",
    "cli",
    "payments",
    "stablecoin",
    "zklogin",
    "agent"
  ],
  "bin": {
    "talise": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
