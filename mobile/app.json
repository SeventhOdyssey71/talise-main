{
  "expo": {
    "name": "Talise",
    "slug": "talise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "talise",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "ios": {
      "bundleIdentifier": "io.talise.app",
      "icon": "./assets/expo.icon",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:talise.io",
        "applinks:www.talise.io",
        "applinks:app.talise.io"
      ]
    },
    "android": {
      "package": "io.talise.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "talise.io"
            },
            {
              "scheme": "https",
              "host": "www.talise.io"
            },
            {
              "scheme": "https",
              "host": "app.talise.io"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Talise uses the camera to scan payment QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
